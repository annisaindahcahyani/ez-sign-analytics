# =============================================================================
# 🛡️ MODULE: DATA PRIVACY & STORAGE (UU PDP COMPLIANCE LAYER)
# =============================================================================
# Mengisolasi isi direktori data menggunakan wildcard (*) agar file database relasional 
# database.sqlite TIDAK AKAN PERNAH bocor ke repositori publik (Data Sovereignty).
data/*

# Pengecualian taktis: Mempertahankan eksistensi fisik folder structural di dalam Git 
# agar pipeline Ingestion/ETL di Docker tidak crash akibat hilangnya direktori staging.
!data/staging/
!data/staging/.gitkeep
!data/staging/psre_files/

# =============================================================================
# 🔑 MODULE: SECURITY & ENVIRONMENT VARIABLES (ANTI-LEAK PROTOCOL)
# =============================================================================
# Mengunci seluruh variasi berkas konfigurasi lingkungan rahasia di tingkat root 
# maupun sub-direktori terdalam (Multi-Layer Protection) demi mematuhi regulasi UU PDP.
**/.env
**/.env.*
**/*.env
.env
.env.local
.env.development
.env.production

# =============================================================================
# 📦 MODULE: DEPENDENCIES & VIRTUAL ENVIRONMENTS
# =============================================================================
# Mengabaikan tumpukan dependensi raksasa. Manajemen paket dieksekusi via CI/CD pipelines.
node_modules/
.venv/
venv/
ENV/
env/
*.piplog
spec/[0-9]*.txt

# =============================================================================
# ⚡ MODULE: BUILD OUTPUTS & CACHE OPTIMIZATION
# =============================================================================
# Mengeliminasi artefak kompilasi dan temporary cache untuk efisiensi space repo.
.next/
.turbo/
out/
dist/
build/
bin/
obj/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ipynb_checkpoints/

# =============================================================================
# 🚀 MODULE: PROJECT ISOLATION (MICRO-FRONTEND COLLABORATION STRATEGY)
# =============================================================================
# Pemisahan/Pengecualian folder repo antarmuka terdekopel guna mencegah anomali Nested Git.
ezsign-frontend/